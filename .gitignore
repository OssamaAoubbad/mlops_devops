# ==========================================
# 1. MLOps Infrastructure & Secrets (Critical)
# ==========================================
# Passwords and local environment variables
.env

# Local storage for MLflow registry and Ray Tune checkpoints
storage/

# Local application logs generated by our RotatingFileHandler
logs/

# ==========================================
# 2. DVC & Data
# ==========================================
# Ignore the raw data folder (DVC handles this via datasets.dvc)
# We use ! to specifically allow the DVC pointer file to be committed
datasets/*
!datasets.dvc
!datasets/.gitignore

# Ignore DVC local configuration (which contains your MinIO passwords)
/.dvc/config.local
/.dvc/tmp/
/.dvc/cache/

# ==========================================
# 3. Python Caches & Compiled Files
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================
# 4. Virtual Environments
# ==========================================
venv/
env/
.venv/
Pipfile.lock

# ==========================================
# 5. Testing & Linting
# ==========================================
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/

# ==========================================
# 6. OS & IDE Specific
# ==========================================
.DS_Store
.vscode/
.idea/
*.swp
*.swo
/datasets


python madewithml/train.py --experiment-name "production_baseline" --dataset-loc "datasets/dataset.csv" --num-workers 1 --cpu-per-worker 4 --num-epochs 1 --batch-size 64